---
interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;
---

<header class="border-b border-surface-lighter bg-surface-light">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/airukan/" class="text-2xl font-bold text-primary-light tracking-tight">
      Airukan
    </a>
    <div class="flex gap-6 text-sm font-medium">
      <a
        href="/airukan/"
        class:list={[
          "transition-colors hover:text-primary-light",
          currentPath === "/airukan/" ? "text-primary-light" : "text-text-muted",
        ]}
      >
        Today
      </a>
      <a
        href="/airukan/schedule"
        class:list={[
          "transition-colors hover:text-primary-light",
          currentPath === "/airukan/schedule" ? "text-primary-light" : "text-text-muted",
        ]}
      >
        Schedule
      </a>
      <a
        href="/airukan/settings"
        class:list={[
          "transition-colors hover:text-primary-light",
          currentPath === "/airukan/settings" ? "text-primary-light" : "text-text-muted",
        ]}
      >
        Settings
      </a>
    </div>
  </nav>
</header>
