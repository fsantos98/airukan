---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import DayColumn from "../components/DayColumn.astro";
import { loadSchedule, loadLastUpdated } from "../lib/data";
import { WEEKDAYS } from "../lib/time";

const schedule = loadSchedule();
const lastUpdated = loadLastUpdated();
---

<Base title="Weekly Schedule">
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold">Weekly Schedule</h1>
      <p class="mt-1 text-text-muted">All currently airing anime by day</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {WEEKDAYS.map((day) => (
        <DayColumn
          day={day}
          entries={schedule.week[day] ?? []}
        />
      ))}
    </div>

    <footer class="mt-12 border-t border-surface-lighter pt-4 text-xs text-text-muted">
      Data last updated: {new Date(lastUpdated.utc).toUTCString()} &middot; Source: {lastUpdated.source}
    </footer>
  </main>
</Base>
