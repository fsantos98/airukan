---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import TimezoneSelector from "../components/TimezoneSelector";
---

<Base title="Settings">
  <Header currentPath={Astro.url.pathname} />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold">Settings</h1>
      <p class="mt-1 text-text-muted">Customize your Airukan experience</p>
    </div>

    <section class="rounded-xl bg-surface-light p-6">
      <h2 class="text-lg font-bold text-primary-light mb-4">Display</h2>
      <TimezoneSelector client:load />
    </section>
  </main>
</Base>
