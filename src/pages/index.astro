---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import AnimeCard from "../components/AnimeCard.astro";
import { loadSchedule, loadLastUpdated } from "../lib/data";
import { WEEKDAYS, getTodayName } from "../lib/time";
import type { AnimeEntry } from "../lib/types";

const schedule = loadSchedule();
const lastUpdated = loadLastUpdated();

// Determine today's day name at build time — will be correct for the static snapshot
const todayKey = getTodayName();
const todayAnime: AnimeEntry[] = schedule.week[todayKey] ?? [];

// Sort by airing time
const sorted = [...todayAnime].sort((a, b) =>
  a.airing_time_jst.localeCompare(b.airing_time_jst)
);

const todayLabel = todayKey.charAt(0).toUpperCase() + todayKey.slice(1);
---

<Base title="Today's Anime">
  <Header />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold">Today's Anime</h1>
      <p class="mt-1 text-text-muted">
        {todayLabel} — {sorted.length} anime airing
      </p>
    </div>

    {sorted.length > 0 ? (
      <div class="flex flex-col gap-4">
        {sorted.map((anime) => (
          <AnimeCard anime={anime} />
        ))}
      </div>
    ) : (
      <div class="rounded-xl bg-surface-light p-12 text-center">
        <p class="text-xl text-text-muted">No anime airing today</p>
        <p class="mt-2 text-sm text-text-muted">
          Check the <a href="/schedule" class="text-primary-light hover:underline">full schedule</a> for other days.
        </p>
      </div>
    )}

    <footer class="mt-12 border-t border-surface-lighter pt-4 text-xs text-text-muted">
      Data last updated: {new Date(lastUpdated.utc).toUTCString()} &middot; Source: {lastUpdated.source}
    </footer>
  </main>
</Base>
