---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import TodayGrid from "../components/TodayGrid";
import { loadSchedule, loadLastUpdated } from "../lib/data";
import type { AnimeEntry } from "../lib/types";

const schedule = loadSchedule();
const lastUpdated = loadLastUpdated();

const allAnime: AnimeEntry[] = Object.values(schedule.week).flat();
---

<Base title="Today's Anime">
  <Header currentPath={Astro.url.pathname} />
  <main class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Today's Anime</h1>
    <TodayGrid client:load allAnime={allAnime} />

    <footer class="mt-12 border-t border-surface-lighter pt-4 text-xs text-text-muted">
      Data last updated: {new Date(lastUpdated.utc).toUTCString()} &middot; Source: {lastUpdated.source}
    </footer>
  </main>
</Base>
